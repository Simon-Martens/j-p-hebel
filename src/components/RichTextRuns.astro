---
import type { RichTextRun } from "../lib/content-types";

interface Props {
  runs: RichTextRun[];
}

const { runs } = Astro.props;

const normalizeTarget = (run: RichTextRun) => {
  if (!run.targetBlank) {
    return {};
  }

  return {
    target: "_blank",
    rel: "noreferrer",
  };
};
---

{
  runs.map((run) => {
    const content = (
      <>
        {run.bold ? <strong>{run.text}</strong> : run.italic ? <em>{run.text}</em> : run.text}
      </>
    );

    return run.href ? (
      <a href={run.href} aria-label={run.ariaLabel} {...normalizeTarget(run)}>
        {content}
      </a>
    ) : (
      content
    );
  })
}
