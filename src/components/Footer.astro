---
const buildDate = new Date().toLocaleDateString("de-DE");
const base = import.meta.env.BASE_URL;
---

<footer class="flex h-8 items-center justify-end border-t border-black/10 bg-gray-300 px-6 text-right text-base leading-none text-slate-700">
  <div>
    © Theodor Springmann Stiftung |
    Stand vom {buildDate} |
    <a href={`${base}kontakt`} class="hover:underline">Kontakt</a> ·
    <a href={`${base}datenschutz`} class="hover:underline">Datenschutz</a>
  </div>
</footer>
