---
import { getCollection } from "astro:content";

const buildDate = new Date().toLocaleDateString("de-DE");
const [siteContent] = await getCollection("site");

if (!siteContent) {
  throw new Error("Missing site content entry.");
}

const base = import.meta.env.BASE_URL;
---

<footer class="flex h-8 items-center justify-end border-t border-black/10 bg-gray-300 px-6 text-right text-base leading-none text-slate-700">
  <div>
    {siteContent.data.footer.copyright} |
    {siteContent.data.footer.buildDatePrefix} {buildDate} |
    <a href={`${base}kontakt`} class="hover:underline">{siteContent.data.footer.links.kontakt}</a> ·
    <a href={`${base}datenschutz`} class="hover:underline">{siteContent.data.footer.links.datenschutz}</a>
  </div>
</footer>
