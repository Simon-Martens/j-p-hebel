---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class={`font-serif ${className}`.trim()}>
	<a href="/" class="flex flex-col">
		<div class="text-6xl text-main sm:text-5xl md:text-6xl lg:text-7xl xl:text-[5.25rem] 2xl:text-8xl">
			<span>JPH</span><span class="text-accent">A</span>
		</div>
		<div class="-mt-1 text-base text-main text-lg md:text-xl lg:text-2xl xl:text-3xl w-fit text-right self-end">
			Heidelberg
		</div>
	</a>
</div>
