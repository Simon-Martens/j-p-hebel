---
import StartLayout from "../layouts/StartLayout.astro";
import Footer from "../components/Footer.astro";
import Logo from "../components/Logo.astro";
import portrait from "../assets/Hebel-Portrait_Mueller_Ausschnitt.jpg";

const base = import.meta.env.BASE_URL;
---

<StartLayout title="Johann Peter Hebel-Archiv">
  <main class="flex min-h-screen flex-col index-page index-page">
    <header class="shrink-0 px-8 font-serif md:mt-12 md:mb-6 mt-6 mb-4">
      <div class="flex w-full flex-col gap-8 lg:gap-12 xl:gap-16 md:mb-6 md:flex-row">
				<div class="md:w-[30%] shrink-0 grow-0 flex md:justify-end mx-auto md:mx-0">
        	<Logo />
				</div>

        <div class="w-full md:hidden">
          <img
            src={portrait.src}
            alt="Ausschnitt eines Porträts von Johann Peter Hebel"
            class="h-auto w-full"
          />
        </div>

        <div class="w-full flex flex-col text-main grow w-[60%]">
          <h1 class="font-light huge">
            Johann Peter Hebel-Archiv
          </h1>
					<h2 class="mt-2.5 huge md:-ml-[0.6rem]"> 
            Ein Projekt der Theodor Springmann Stiftung
          </h2>
        </div>
      </div>
    </header>

    <section class="hidden min-h-0 overflow-hidden md:block xl:hidden">
      <img
        src={portrait.src}
        alt="Ausschnitt eines Porträts von Johann Peter Hebel"
        class="relative left-1/2 h-full w-[clamp(120vw,130vw,145vw)] max-w-none -translate-x-1/2 object-cover"
      />
    </section>

    <section class="hidden min-h-0 xl:block">
      <img
        src={portrait.src}
        alt="Ausschnitt eines Porträts von Johann Peter Hebel"
        class="h-full w-full object-cover"
      />
    </section>

    <section class="shrink-0">
      <div class="px-8 md:px-14 md:py-4">
        <div class="mx-auto flex w-full max-w-[1680px] flex-col gap-6 text-center md:flex-row md:justify-between md:gap-12">
          <a href={`${base}edition`} class="block flex-1 hover:underline">
            <span class="text-fluid-link text-accent">Sämtliche Schriften</span><br />
            <span class="text-fluid-link text-[#1f365c]">
              Historisch-kritische Edition<br />
              und Kommentar
            </span>
          </a>

          <a href={`${base}tagung`} class="block flex-1 hover:underline">
            <span class="text-fluid-link text-accent">Tagung</span><br />
            <span class="text-fluid-link text-[#1f365c]">
              »Neue Zugänge zu Hebels Briefwerk«
            </span>
          </a>

          <a href={`${base}ausstellung`} class="block flex-1 hover:underline">
            <span class="text-fluid-link text-accent">Virtuelle Ausstellung</span><br />
            <span class="text-fluid-link text-[#1f365c]">
              »Das Nachleben der Worte«
            </span>
          </a>
        </div>
      </div>

    </section>
		<div class="grow shrink-0">
		</div>
    <Footer />
  </main>
</StartLayout>
