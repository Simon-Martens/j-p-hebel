---
import { getCollection } from "astro:content";
import SubpageLayout from "../layouts/SubpageLayout.astro";
import Footer from "../components/Footer.astro";
import Logo from "../components/Logo.astro";
import manuscript from "../assets/AG3_Ausschnitt.jpg";

const [editionPage] = await getCollection("editionPage");

if (!editionPage) {
  throw new Error("Missing edition page content.");
}

const content = editionPage.data;
---

<SubpageLayout
  title={content.seo.title}
  description={content.seo.description}
	pathname="/edition"
  image={manuscript}
  currentPage="edition"
>
  <main class="flex min-h-screen flex-col">

    <header class="shrink-0 px-8 py-4 font-serif">
      <div class="my-3 md:my-6 flex w-full flex-col items-center gap-8 lg:gap-12 xl:gap-16 md:mb-6 md:flex-row">
				<div class="md:w-[35%] shrink-0 grow-0 flex md:justify-end mx-auto md:mx-0">
        	<Logo class="" />
				</div>

        <div class="md:w-full flex flex-col text-main grow md:w-[60%]">
					<h1 class="font-light mid sm:ml-[0.3rem] md:ml-[0.4rem] lg:ml-[0.5rem] xl:ml-[0.6rem]">
            {content.hero.eyebrow}
          </h1>
					<div class="mt-3">
						<h1 class="mid text-accent">
							{content.hero.title}
						</h1>
						<h2 class="text-base text-main sm:text-xl md:text-xl lg:text-2xl xl:text-3xl mt-1">
							{content.hero.subtitle}
						</h2>
					</div>
					<div class="mt-1 hidden md:block"> 
            {content.hero.foundationText}
          </div>
        </div>
      </div>
    </header>


    <section class="relative overflow-hidden px-4 pb-8 pt-4 md:px-8 md:pb-12 lg:px-14">
      <img
        src={manuscript.src}
        alt={content.imageAlt}
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-paper/20"></div>

      <div class="relative mx-auto max-w-4xl">
        <article class="edition-overview mx-auto max-w-5xl bg-stone-200 px-6 py-7 text-[#1f365c] shadow-[0_12px_40px_rgba(0,0,0,0.08)] md:px-10 md:py-10">
          <header class="edition-overview-header">
            <h2 class="text-accent text-3xl mb-6 font-semibold">{content.overviewTitle}</h2>
          </header>

          <div class="edition-overview-body">
            <section class="edition-entry">
              <h3 class="edition-entry-title">
								{content.introStudy.title}
              </h3>
							<div class="edition-entry-desc">
              {content.introStudy.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
							</div>
            </section>

            {
              content.volumes.map((volume) => (
                <section class="edition-entry">
                  <h3 class="edition-entry-title">
                    {volume.band} <span class="edition-entry-meta">{volume.title}. {volume.pages}</span>
                  </h3>
									<div class="edition-entry-desc">
                  {volume.lines.map((line) => <p>{line}</p>)}
									</div>
                </section>
              ))
            }
          </div>
        </article>
      </div>
    </section>

    <div class="mt-auto">
      <Footer />
    </div>
  </main>
</SubpageLayout>
