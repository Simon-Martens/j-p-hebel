---
import StartLayout from "../layouts/StartLayout.astro";
import Footer from "../components/Footer.astro";
import Logo from "../components/Logo.astro";
import manuscript from "../assets/AG3_Ausschnitt.jpg";

const volumes = [
  {
    band: "I",
    title: "Gedichte",
    pages: "Ca. 350 Seiten",
    lines: [
      "Alemannische Gedichte. Hochdeutsche Dichtungen. Rätsel.",
      "(erscheint voraussichtlich 2027)",
    ],
  },
  {
    band: "II/III",
    title: "Erzählungen und Aufsätze",
    pages: "660 S.",
    lines: [
      "Die Kalenderbeiträge des rheinländischen Hausfreundes. Sonstige Prosa. (Mit den Holzstichen der Kalender)",
      "Herausgegeben von Adrian Braunbehrens und Peter Pfaff unter Mitwirkung von Bernhard Oswald",
      "Verlag C. F. Müller Karlsruhe 1990, ISBN 3-7880-9785-x",
    ],
  },
  {
    band: "IV",
    title: "Apparat zu den Bänden I-III",
    pages: "Ca. 350 Seiten",
    lines: [
      "Das Verfahren der Edition. Textgeschichte. Die Varianten in den Handschriften und autorisierten Drucken.",
      "(erscheint voraussichtlich 2027)",
    ],
  },
  {
    band: "V",
    title: "Biblische Geschichten",
    pages: "318 S.",
    lines: [
      "Biblische Geschichten, Text- und Druckgeschichte, Textvarianten",
      "Herausgegeben von Gustav Adolf Benrath und Adrian Braunbehrens unter Mitwirkung von Gerd Müller",
      "Verlag C. F. Müller Karlsruhe 1991, ISBN 3-7880-9805-8",
    ],
  },
  {
    band: "VI/VII",
    title: "Predigten und Predigtentwürfe",
    pages: "850 S.",
    lines: [
      "Predigten und Predigtentwürfe, Text- und Druckgeschichte, Textvarianten, Dokumentation, Register",
      "Herausgegeben von Johann Anselm Steiger und Mitwirkung von Thomas Illig",
      "Stroemfeld Verlag Frankfurt am Main 2010, ISBN 978-3-87877-534-3",
    ],
  },
  {
    band: "VIII",
    title: "Theologische Schriften",
    pages: "388 S.",
    lines: [
      "Katechismus, Beiträge zur Liturgie und Religionswissenschaft, Text- und Druckgeschichte, Textvarianten, Dokumentation, Register",
      "Herausgegeben von Johann Anselm Steiger und Mitwirkung von Thomas Illig",
      "Stroemfeld Verlag Frankfurt am Main 2013, ISBN 978-3-87877-537-9",
    ],
  },
  {
    band: "IX/X",
    title: "Amtschriften und nachgelassene Aufzeichnungen",
    pages: "Ca. 500 Seiten",
    lines: [
      "Gutachten und Amtschriften. Auszüge aus Büchern und Zeitschriften. Entwürfe für den Unterricht. Gedanken, Einfälle und Träume. Ca. 500 Seiten",
      "(in Vorbereitung)",
    ],
  },
  {
    band: "X–XII",
    title: "Hebels Briefe",
    pages: "Ca. 1000 Seiten",
    lines: [
      "Briefe, Textvarianten, Register. Ca. 1000 Seiten",
      "(in Vorbereitung)",
    ],
  },
];
---

<StartLayout title="Johann Peter Hebel | Sämtliche Schriften">
  <main class="flex min-h-screen flex-col">
    <section class="edition-page-header px-6 py-5 md:px-10 md:py-8">
      <div class="edition-page-header-inner mx-auto flex max-w-[1680px] flex-col gap-6 md:flex-row md:items-center md:justify-center md:gap-20">
        <Logo class="edition-logo-block shrink-0" />

        <div class="">
          <h1 class="font-serif text-5xl">
            Johann Peter Hebel
          </h1>
					<div class="font-sans ml-18 mt-2">
						<h1 class="text-6xl text-accent">
							Sämtliche Schriften
						</h1>
						<p class="text-logo-sub">
							Historisch-kritische Edition und Kommentar
						</p>
					</div>
          <p class="text-logo-sub-small font-serif">
            Die Ausgabe ist ein Projekt der Theodor Springmann Stiftung.
          </p>
        </div>
      </div>
    </section>

    <section class="relative overflow-hidden px-4 pb-8 pt-2 md:px-8 md:pb-12 lg:px-14">
      <img
        src={manuscript.src}
        alt="Ausschnitt aus einer Hebel-Handschrift"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-paper/35"></div>

      <div class="relative mx-auto max-w-[1680px]">
        <article class="edition-overview mx-auto max-w-5xl bg-[#d8d8d8] px-6 py-7 text-[#1f365c] shadow-[0_12px_40px_rgba(0,0,0,0.08)] md:px-10 md:py-10">
          <header class="edition-overview-header">
            <h2 class="edition-overview-title font-sans">Übersicht</h2>
          </header>

          <div class="edition-overview-body">
            <section class="edition-entry">
              <p class="edition-entry-title">
                Vorstudie zur Historisch-Kritischen Gesamtausgabe. 84 S.
              </p>
							<div class="edition-entry-desc">
              <p>
                Enthält u. a. einen Bericht der Herausgeber, die Urfassung von »Der
                Statthalter von Schopfheim« und »Der Spaziergang zum See«
              </p>
              <p>
                Herausgegeben von Adrian Braunbehrens und Peter Pfaff
              </p>
              <p>Verlag C. F. Müller Karlsruhe 1988, ISBN 3-7880-9766-3</p>
							</div>
            </section>

            {
              volumes.map((volume) => (
                <section class="edition-entry">
                  <h3 class="edition-entry-title">
                    {volume.band} <span class="edition-entry-meta">{volume.title}. {volume.pages}</span>
                  </h3>
									<div class="edition-entry-desc">
                  {volume.lines.map((line) => <p>{line}</p>)}
									</div>
                </section>
              ))
            }
          </div>
        </article>
      </div>
    </section>

    <div class="mt-auto">
      <Footer />
    </div>
  </main>
</StartLayout>
