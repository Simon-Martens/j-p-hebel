---
import { getCollection } from "astro:content";
import SubpageLayout from "../layouts/SubpageLayout.astro";
import Footer from "../components/Footer.astro";
import Logo from "../components/Logo.astro";
import RichTextBlocks from "../components/RichTextBlocks.astro";
import portrait from "../assets/Hebel-Portrait_Mueller_Ausschnitt.jpg";

const [datenschutzPage] = await getCollection("datenschutzPage");

if (!datenschutzPage) {
  throw new Error("Missing datenschutz page content.");
}

const content = datenschutzPage.data;
---

<SubpageLayout
  title={content.seo.title}
  description={content.seo.description}
  pathname="/datenschutz"
  image={portrait}
  currentPage="datenschutz"
>
  <main class="flex min-h-screen flex-col">
    <header class="shrink-0 px-8 font-serif md:mt-12 md:mb-6 mt-6 mb-4">
      <div class="flex w-full flex-col gap-8 lg:gap-12 xl:gap-16 md:mb-6 md:flex-row">
        <div class="shrink-0 grow-0 md:w-[35%] flex md:justify-end mx-auto md:mx-0">
          <Logo />
        </div>

        <div class="w-full flex flex-col text-main grow w-[60%]">
          <h1 class="font-light huge">
            {content.heroTitle}
          </h1>
        </div>
      </div>
    </header>
	<div class="mx-4 my-8 md:ml-12 flex flex-col h-full max-w-[62rem]">
		<div class="datenschutz-content mx-auto max-w-3xl font-serif text-lg leading-relaxed [&_a]:underline [&_h2]:font-semibold [&_h3]:font-semibold [&_p]:mb-3">
      <div class="mb-6 border border-black px-6 pb-4 pt-5">
        <RichTextBlocks blocks={content.noticeBlocks} />
      </div>
      <RichTextBlocks blocks={content.contentBlocks} />
		</div>
	</div>
    <Footer />
  </main>
</SubpageLayout>
