---
import SubpageLayout from "../layouts/SubpageLayout.astro";
import Footer from "../components/Footer.astro";
import Logo from "../components/Logo.astro";
import portrait from "../assets/Hebel-Portrait_Mueller_Ausschnitt.jpg";
---

<SubpageLayout
  title="Kontakt | Johann Peter Hebel-Archiv"
  description="Kontakt zum Johann Peter Hebel-Archiv und zur Theodor-Springmann-Stiftung in Heidelberg."
  pathname="/kontakt"
  image={portrait}
  currentPage="kontakt"
>
  <main class="flex min-h-screen flex-col">
    <header class="shrink-0 px-8 font-serif md:mt-12 md:mb-6 mt-6 mb-4">
      <div class="flex w-full flex-col gap-8 lg:gap-12 xl:gap-16 md:mb-6 md:flex-row">
        <div class="shrink-0 grow-0 md:w-[35%] flex md:justify-end mx-auto md:mx-0">
          <Logo />
        </div>

        <div class="w-full flex flex-col text-main grow w-[60%]">
          <h1 class="font-light huge">
            Kontakt
          </h1>
        </div>
      </div>
    </header>

    <section class="grow px-8 pb-8">
      <div class="flex w-full flex-col gap-8 lg:gap-12 xl:gap-16 md:flex-row">
        <div class="shrink-0 grow-0 md:w-[35%]"></div>

        <div class="w-full flex flex-col text-main grow w-[60%]">
          <div class="font-serif text-main text-lg leading-relaxed md:text-xl">
            <p>Dr. Alexander Knopf</p>
            <p>Theodor-Springmann-Stiftung</p>
            <p>Hirschgasse 2</p>
            <p>D – 69120 Heidelberg</p>
            <p class="mt-6">Tel.: 06221-7258746</p>
            <p class="mt-6">E-Mail: knopf@tss-hd.de</p>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</SubpageLayout>
