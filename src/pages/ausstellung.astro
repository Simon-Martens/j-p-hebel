---
import StartLayout from "../layouts/StartLayout.astro";
import Footer from "../components/Footer.astro";
import cover from "../assets/biblische_geschichten_cover.jpg";
---

<StartLayout title="Johann Peter Hebel | Das Nachleben der Worte">
  <main class="flex min-h-screen flex-col">
    <header class="shrink-0 px-8 py-4 font-serif">
      <div class="mb-6 flex-col mx-auto flex-col items-center gap-8 lg:gap-12 xl:gap-16 md:mb-6 md:flex-row">
        <h1 class="font-light sm text-center text-accent">
          Ausstellung
        </h1>

        <div class="mt-4">
          <h1 class="sm text-center leading-tight">
            Johann Peter Hebel<br>
            Das Nachleben der Worte
          </h1>
        </div>
      </div>
    </header>

    <section class="relative flex-1 overflow-hidden px-4 pb-8 pt-8 md:pt-6 md:px-8 md:pb-12 lg:px-6 xl:px-8">
      <img
        src={cover.src}
        alt="Biblische Geschichten, Coverdetail mit lesendem Engel"
        class="absolute inset-0 h-full w-full object-cover object-center"
      />

      <div class="relative mx-auto flex min-h-[38rem] max-w-[104rem] flex-col gap-8 lg:min-h-[42rem]">
        <article class="hidden lg:block order-1 mt-4 w-full max-w-xl bg-paper/45 px-4 py-4 font-serif text-main md:px-6 md:py-5 lg:absolute lg:left-0 lg:top-4 lg:mt-0 xl:-ml-4 2xl:-ml-8">
          <div class="space-y-1 text-lg leading-tight font-bold md:text-2xl">
            <p class="text-accent">Theodor Springmann Stiftung</p>
            <p>Hebel-Archiv Heidelberg</p>
            <p>Historische Edition sämtlicher Schriften</p>
          </div>
        </article>

        <div class="flex flex-col gap-6 lg:absolute lg:bottom-0 lg:left-0 lg:w-full lg:flex-row lg:items-start lg:justify-between">
          <article class="w-full bg-slate-900 px-4 py-4 font-serif text-paper shadow-xl md:max-w-xl md:px-6 md:py-5 lg:mt-10 lg:ml-0 xl:-ml-4 2xl:-ml-8">
            <p class="text-lg leading-tight md:text-2xl">
              Eine virtuelle Ausstellung zu Hebels schriftstellerischem Wirken anlässlich seines 200. Todestages am 22. September 2026
            </p>
          </article>

          <aside class="flex justify-center md:justify-end lg:shrink-0 lg:pr-0 xl:-mr-4 2xl:-mr-8 mx-auto lg:mx-0 mt-16 lg:mt-0">
            <div
              class="relative h-48 w-48 rounded-full shadow-[0_14px_28px_rgba(0,0,0,0.24)] md:h-56 md:w-56"
            >
              <div class="absolute inset-0 rounded-full bg-black"></div>
              <div class="absolute inset-[2px] flex flex-col items-center justify-center rounded-full bg-paper px-6 text-center font-serif font-bold text-accent md:inset-[3px]">
                <p class="text-2xl italic md:text-4xl">online</p>
                <p class="mt-2 text-2xl md:text-4xl">1. September</p>
                <p class="mt-1 text-2xl md:text-4xl">2026</p>
              </div>
            </div>
          </aside>
        </div>
				<div class="grow shrink-0">
				</div>
        <article class="lg:hidden order-3 mt-4 w-full max-w-xl bg-paper/75 px-4 py-4 font-serif text-main ">
          <div class="space-y-1 text-sm leading-tight font-bold">	
            <p class="text-accent">Theodor Springmann Stiftung</p>
            <p>Hebel-Archiv Heidelberg</p>
            <p>Historische Edition sämtlicher Schriften</p>
          </div>
        </article>
      </div>
    </section>

    <Footer />
  </main>
</StartLayout>
